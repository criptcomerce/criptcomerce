# NOWPayments
NOWPAYMENTS_API_KEY=your_nowpayments_api_key_here
NOWPAYMENTS_IPN_SECRET=your_ipn_secret_here
NOWPAYMENTS_API_URL=https://api.nowpayments.io

# Wallets centrais
CENTRAL_BTC_WALLET=bc1YourCentralBTCWalletAddress
CENTRAL_ETH_WALLET=0xYourCentralETHWalletAddress
CENTRAL_USDT_WALLET=0xYourCentralUSDTWalletAddress

# Banco de dados
DATABASE_URL=postgresql://user:password@localhost:5432/crypto_payments

# App
PORT=3000
NODE_ENV=development
